<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/labvirtual/db" VERSION="20260611"
    COMMENT="XMLDB file for local plugin labvirtual"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="local_labvirtual_batches" COMMENT="Lab Virtual batches (turmas de laboratório)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" COMMENT="Batch name (e.g. Projeto de Interface 2026/1)"/>
        <FIELD NAME="categoryid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Moodle course_categories.id — the batch own subcategory"/>
        <FIELD NAME="nameprefix" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT="" SEQUENCE="false" COMMENT="Lab name prefix (e.g. Lab EAD → Lab EAD 01)"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Unix timestamp of batch creation"/>
        <FIELD NAME="maxteachers" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Per-batch override for max editors per lab; NULL uses the global default"/>
        <FIELD NAME="lifecyclemonths" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Per-batch override for lifecycle months; NULL uses the global default"/>
        <FIELD NAME="lifecycleaction" TYPE="int" LENGTH="4" NOTNULL="false" SEQUENCE="false" COMMENT="Per-batch override for lifecycle action; NULL uses the global default"/>
        <FIELD NAME="warningdays" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Per-batch override for warning days; NULL uses the global default"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="local_labvirtual_batch_teachers" COMMENT="Responsible teachers per batch (N-to-N)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="batchid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="FK local_labvirtual_batches.id"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="FK user.id — responsible teacher"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="batchid-userid" UNIQUE="true" FIELDS="batchid, userid"/>
        <INDEX NAME="userid" UNIQUE="false" FIELDS="userid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_labvirtual_courses" COMMENT="Lab Virtual individual labs (sandbox courses)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="batchid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="FK local_labvirtual_batches.id"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="FK course.id — managed sandbox course"/>
        <FIELD NAME="enrolid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="FK enrol.id — manual enrolment instance used by the panel"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Unix timestamp of lab creation — base for lifecycle"/>
        <FIELD NAME="lastreset" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Unix timestamp of last successful reset (0 = never)"/>
        <FIELD NAME="lastwarn" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Unix timestamp of last lifecycle warning email sent to the teacher (0 = never)"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid" UNIQUE="true" FIELDS="courseid"/>
        <INDEX NAME="batchid" UNIQUE="false" FIELDS="batchid"/>
        <INDEX NAME="timecreated" UNIQUE="false" FIELDS="timecreated"/>
        <INDEX NAME="enrolid" UNIQUE="false" FIELDS="enrolid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
