{{!
    @template local_virtuallab/labs_panel

    Student self-service panel for choosing a lab sandbox within a batch.

    Example context (json):
    {
        "batchname": "Projeto de Interface 2026/1",
        "teachername": "Jean Lúcio",
        "batchid": 1,
        "canmanage": true,
        "sesskey": "abc123",
        "viewurl": "/local/virtuallab/view.php?batchid=1",
        "haslabs": true,
        "labs": [
            {
                "labid": 1,
                "courseid": 42,
                "coursename": "Lab EAD 01",
                "courseurl": "/course/view.php?id=42",
                "can_enrol_editor": true,
                "can_enrol_visitor": true,
                "user_enrolled_here": false,
                "user_is_editor_anywhere": false,
                "editor_blocked_elsewhere": false,
                "editor_block_aria": "Lab full",
                "status_available": true,
                "status_in_use": false,
                "status_full": false,
                "statuslabel": "Disponível",
                "editorcount": 0,
                "slotsleft_label": "2 vagas",
                "deadline_label": "Delete on 12 Sep 2026",
                "editors": []
            }
        ]
    }
}}
<div class="local-virtuallab-panel">
    <div class="page-header mb-4">
        <p class="mb-1">
            <i class="fa fa-user-tie me-1" aria-hidden="true"></i>
            {{teachername}}
        </p>
    </div>

    {{#haslabs}}
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th scope="col">Ambiente</th>
                    <th scope="col">Status</th>
                    <th scope="col">{{#str}} currenteditors, local_virtuallab {{/str}}</th>
                    {{#canmanage}}
                    <th scope="col">{{#str}} view_course, local_virtuallab {{/str}}</th>
                    {{/canmanage}}
                    <th scope="col">{{#str}} enrol_join, local_virtuallab {{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#labs}}
                <tr>
                    <td><strong>{{coursename}}</strong></td>
                    <td class="text-nowrap">
                        <span class="badge {{#status_available}}bg-success{{/status_available}}{{#status_in_use}}bg-warning text-dark{{/status_in_use}}{{#status_full}}bg-danger{{/status_full}}">
                            {{statuslabel}}
                        </span>
                        {{#slotsleft_label}}
                        <span class="badge lv-badge-slots ms-1">{{slotsleft_label}}</span>
                        {{/slotsleft_label}}
                        {{#deadline_label}}
                        <div class="small text-body-secondary mt-1">
                            <i class="fa fa-clock me-1" aria-hidden="true"></i>{{deadline_label}}
                        </div>
                        {{/deadline_label}}
                    </td>
                    <td>
                        {{#editors}}
                            <span class="d-block">{{fullname}}</span>
                        {{/editors}}
                        {{^editors}}
                            <span class="text-body-secondary">—</span>
                        {{/editors}}
                    </td>
                    {{#canmanage}}
                    <td>
                        <a href="{{courseurl}}"
                           class="btn btn-sm btn-outline-secondary"
                           aria-label="{{#str}} view_course_label, local_virtuallab, {{coursename}} {{/str}}">
                            <i class="fa fa-eye me-1" aria-hidden="true"></i>
                            {{#str}} view_course, local_virtuallab {{/str}}
                        </a>
                    </td>
                    {{/canmanage}}
                    <td class="text-nowrap">
                        {{#user_enrolled_here}}
                        <span class="badge bg-secondary lv-badge-enrolled me-1">
                            {{#str}} already_enrolled, local_virtuallab {{/str}}
                        </span>
                        <form method="post" action="{{viewurl}}" class="d-inline">
                            <input type="hidden" name="action" value="leave">
                            <input type="hidden" name="batchid" value="{{batchid}}">
                            <input type="hidden" name="courseid" value="{{courseid}}">
                            <input type="hidden" name="sesskey" value="{{sesskey}}">
                            <button type="submit"
                                    class="btn btn-sm btn-outline-danger"
                                    aria-label="{{#str}} leave_lab_label, local_virtuallab, {{coursename}} {{/str}}">
                                <i class="fa fa-arrow-right-from-bracket me-1" aria-hidden="true"></i>
                                {{#str}} leave_lab, local_virtuallab {{/str}}
                            </button>
                        </form>
                        {{/user_enrolled_here}}
                        {{^user_enrolled_here}}
                        {{#can_enrol_editor}}
                        <form method="post" action="{{viewurl}}" class="d-inline">
                            <input type="hidden" name="action" value="enrol">
                            <input type="hidden" name="batchid" value="{{batchid}}">
                            <input type="hidden" name="courseid" value="{{courseid}}">
                            <input type="hidden" name="role" value="editor">
                            <input type="hidden" name="sesskey" value="{{sesskey}}">
                            <button type="submit"
                                    class="btn btn-sm btn-primary me-1"
                                    aria-label="{{#str}} access_as_editor, local_virtuallab, {{coursename}} {{/str}}">
                                {{#str}} report_role_editor, local_virtuallab {{/str}}
                            </button>
                        </form>
                        {{/can_enrol_editor}}
                        {{^can_enrol_editor}}
                        <button type="button"
                                class="btn btn-sm btn-primary me-1"
                                disabled
                                aria-label="{{editor_block_aria}}">
                            {{#str}} report_role_editor, local_virtuallab {{/str}}
                        </button>
                        {{/can_enrol_editor}}
                        <form method="post" action="{{viewurl}}" class="d-inline">
                            <input type="hidden" name="action" value="enrol">
                            <input type="hidden" name="batchid" value="{{batchid}}">
                            <input type="hidden" name="courseid" value="{{courseid}}">
                            <input type="hidden" name="role" value="visitor">
                            <input type="hidden" name="sesskey" value="{{sesskey}}">
                            <button type="submit"
                                    class="btn btn-sm btn-outline-secondary"
                                    aria-label="{{#str}} access_as_visitor, local_virtuallab, {{coursename}} {{/str}}">
                                {{#str}} report_role_visitor, local_virtuallab {{/str}}
                            </button>
                        </form>
                        {{#editor_blocked_elsewhere}}
                        <div class="small text-body-secondary mt-1">
                            <i class="fa fa-circle-info me-1" aria-hidden="true"></i>{{editor_block_aria}}
                        </div>
                        {{/editor_blocked_elsewhere}}
                        {{/user_enrolled_here}}
                    </td>
                </tr>
                {{/labs}}
            </tbody>
        </table>
    </div>
    {{/haslabs}}
    {{^haslabs}}
    <p class="text-body-secondary">{{#str}} nolabs, local_virtuallab {{/str}}</p>
    {{/haslabs}}
</div>
