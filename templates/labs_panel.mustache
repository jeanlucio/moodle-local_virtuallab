{{!
    @template local_labvirtual/labs_panel

    Student self-service panel for choosing a lab sandbox within a batch.

    Example context (json):
    {
        "batchname": "Projeto de Interface 2026/1",
        "teachername": "Jean Lúcio",
        "batchid": 1,
        "sesskey": "abc123",
        "viewurl": "/local/labvirtual/view.php?batchid=1",
        "haslabs": true,
        "labs": [
            {
                "labid": 1,
                "courseid": 42,
                "coursename": "Lab EAD 01",
                "teacher_enrolid": 10,
                "student_enrolid": 11,
                "teacherkey": "ABC123",
                "studentkey": "XYZ789",
                "showkeys": true,
                "can_enrol_editor": true,
                "status_available": true,
                "status_in_use": false,
                "status_full": false,
                "statuslabel": "Disponível",
                "editorcount": 0,
                "editors": []
            }
        ]
    }
}}
<div class="local-labvirtual-panel">
    <div class="page-header mb-4">
        <h2>{{batchname}}</h2>
        <p class="text-body-secondary">
            <i class="fa fa-user-tie me-1" aria-hidden="true"></i>
            {{teachername}}
        </p>
    </div>

    {{#haslabs}}
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th scope="col">{{#str}} pluginname, local_labvirtual {{/str}}</th>
                    <th scope="col">Status</th>
                    <th scope="col">{{#str}} currenteditors, local_labvirtual {{/str}}</th>
                    {{#labs}}{{#showkeys}}
                    <th scope="col">{{#str}} key_editor, local_labvirtual {{/str}}</th>
                    <th scope="col">{{#str}} key_visitor, local_labvirtual {{/str}}</th>
                    {{/showkeys}}{{/labs}}
                    <th scope="col">{{#str}} view_panel, local_labvirtual {{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#labs}}
                <tr>
                    <td><strong>{{coursename}}</strong></td>
                    <td>
                        <span class="badge {{#status_available}}bg-success{{/status_available}}{{#status_in_use}}bg-warning text-dark{{/status_in_use}}{{#status_full}}bg-danger{{/status_full}}">
                            {{statuslabel}}
                        </span>
                    </td>
                    <td>
                        {{#editors}}
                            <span class="d-block">{{fullname}}</span>
                        {{/editors}}
                        {{^editors}}
                            <span class="text-body-secondary">—</span>
                        {{/editors}}
                    </td>
                    {{#showkeys}}
                    <td>
                        {{#teacherkey}}<code>{{teacherkey}}</code>{{/teacherkey}}
                        {{^teacherkey}}<span class="text-body-secondary">—</span>{{/teacherkey}}
                    </td>
                    <td>
                        {{#studentkey}}<code>{{studentkey}}</code>{{/studentkey}}
                        {{^studentkey}}<span class="text-body-secondary">—</span>{{/studentkey}}
                    </td>
                    {{/showkeys}}
                    <td>
                        {{#can_enrol_editor}}
                        <form method="post" action="{{viewurl}}" class="d-inline">
                            <input type="hidden" name="action" value="enrol">
                            <input type="hidden" name="batchid" value="{{batchid}}">
                            <input type="hidden" name="courseid" value="{{courseid}}">
                            <input type="hidden" name="enrolid" value="{{teacher_enrolid}}">
                            <input type="hidden" name="sesskey" value="{{sesskey}}">
                            <button type="submit"
                                    class="btn btn-sm btn-primary me-1"
                                    aria-label="{{#str}} access_as_editor, local_labvirtual, {{coursename}} {{/str}}">
                                {{#str}} key_editor, local_labvirtual {{/str}}
                            </button>
                        </form>
                        {{/can_enrol_editor}}
                        {{^can_enrol_editor}}
                        <button type="button"
                                class="btn btn-sm btn-primary me-1"
                                disabled
                                aria-label="{{#str}} lab_full, local_labvirtual {{/str}}">
                            {{#str}} key_editor, local_labvirtual {{/str}}
                        </button>
                        {{/can_enrol_editor}}
                        <form method="post" action="{{viewurl}}" class="d-inline">
                            <input type="hidden" name="action" value="enrol">
                            <input type="hidden" name="batchid" value="{{batchid}}">
                            <input type="hidden" name="courseid" value="{{courseid}}">
                            <input type="hidden" name="enrolid" value="{{student_enrolid}}">
                            <input type="hidden" name="sesskey" value="{{sesskey}}">
                            <button type="submit"
                                    class="btn btn-sm btn-outline-secondary"
                                    aria-label="{{#str}} access_as_visitor, local_labvirtual, {{coursename}} {{/str}}">
                                {{#str}} key_visitor, local_labvirtual {{/str}}
                            </button>
                        </form>
                    </td>
                </tr>
                {{/labs}}
            </tbody>
        </table>
    </div>
    {{/haslabs}}
    {{^haslabs}}
    <p class="text-body-secondary">{{#str}} nolabs, local_labvirtual {{/str}}</p>
    {{/haslabs}}
</div>
