{{!
    @template local_virtuallab/manage_labs

    List of labs within a batch for the admin management page.
    Includes per-row reset/delete actions and a bulk action form.

    Example context (json):
    {
        "batchname": "Interface Design 2026/1",
        "batchid": 1,
        "manageurl": "/local/virtuallab/manage.php",
        "labs": [
            {
                "id": 1,
                "coursename": "Lab 01",
                "shortname": "lab-b1-lab01",
                "courseurl": "/course/view.php?id=42",
                "lastreset": "—",
                "nextaction": "Delete on 12 Sep 2026",
                "reseturl": "/local/virtuallab/manage.php?batchid=1&action=resetlab&labid=1",
                "deleteurl": "/local/virtuallab/manage.php?batchid=1&action=deletelab&labid=1",
                "resetlabel": "Reset lab: Lab 01",
                "deletelabel": "Delete lab: Lab 01"
            }
        ],
        "haslabs": true,
        "scheduledlabel": "Scheduled: delete on 12 Sep 2026",
        "divergent": false,
        "panelurl": "https://moodle.example.com/local/virtuallab/view.php?batchid=1",
        "qrsvg": "data:image/svg+xml;base64,PHN2Zy8+",
        "qralt": "Student panel QR code",
        "createurl": "/local/virtuallab/manage.php?batchid=1&action=createlabs",
        "editurl": "/local/virtuallab/manage.php?batchid=1&action=editbatch",
        "syncurl": "/local/virtuallab/manage.php?batchid=1&action=syncchecklist&sesskey=abc123",
        "sesskey": "abc123",
        "strpanelhelp": "Share this URL with students..."
    }
}}
<div class="local-virtuallab-manage-labs">
    <div class="mb-3 d-flex justify-content-end">
        {{#syncurl}}
        <a href="{{syncurl}}" class="btn btn-outline-secondary me-2">
            <i class="fa fa-list-check me-1" aria-hidden="true"></i>
            {{#str}} apply_checklist_existing, local_virtuallab {{/str}}
        </a>
        {{/syncurl}}
        {{#editurl}}
        <a href="{{editurl}}" class="btn btn-outline-secondary">
            <i class="fa fa-pen me-1" aria-hidden="true"></i>
            {{#str}} edit_batch, local_virtuallab {{/str}}
        </a>
        {{/editurl}}
    </div>

    <div class="card mb-4 border-primary">
        <div class="card-header bg-primary text-white">
            <i class="fa fa-link me-1" aria-hidden="true"></i>
            {{#str}} panel_url, local_virtuallab {{/str}}
        </div>
        <div class="card-body">
            <p class="text-body-secondary small mb-2">{{strpanelhelp}}</p>
            <div class="input-group">
                <input type="text"
                       id="local-virtuallab-panel-url"
                       class="form-control"
                       readonly
                       value="{{panelurl}}"
                       aria-label="{{#str}} panel_url, local_virtuallab {{/str}}">
                <button class="btn btn-outline-secondary"
                        type="button"
                        id="local-virtuallab-copy-link"
                        data-action="copytoclipboard"
                        data-clipboard-target="#local-virtuallab-panel-url"
                        data-clipboard-success-message="{{#str}} panel_url_copied, local_virtuallab {{/str}}"
                        aria-label="{{#str}} copy_panel_link, local_virtuallab {{/str}}">
                    <i class="fa fa-clipboard" aria-hidden="true"></i>
                    {{#str}} copy_panel_link, local_virtuallab {{/str}}
                </button>
            </div>
            {{#qrsvg}}
            <div class="mt-2 text-end">
                <button type="button"
                        class="btn btn-sm btn-outline-secondary"
                        data-bs-toggle="collapse"
                        data-toggle="collapse"
                        data-bs-target="#local-virtuallab-qrcode-{{batchid}}"
                        data-target="#local-virtuallab-qrcode-{{batchid}}"
                        aria-expanded="false"
                        aria-controls="local-virtuallab-qrcode-{{batchid}}">
                    <i class="fa fa-qrcode me-1" aria-hidden="true"></i>
                    {{#str}} show_qrcode, local_virtuallab {{/str}}
                </button>
            </div>
            <div class="collapse" id="local-virtuallab-qrcode-{{batchid}}">
                <div class="text-center mt-3">
                    <img src="{{qrsvg}}"
                         alt="{{qralt}}"
                         class="local-virtuallab-qrcode-img">
                </div>
            </div>
            {{/qrsvg}}
        </div>
    </div>

    {{#haslabs}}
    {{#scheduledlabel}}
    <p class="text-body-secondary mb-3">
        <i class="fa fa-clock me-1" aria-hidden="true"></i>{{scheduledlabel}}
    </p>
    {{/scheduledlabel}}
    <div class="mb-3 d-flex justify-content-end">
        <a href="{{createurl}}" class="btn btn-success">
            <i class="fa fa-plus me-1" aria-hidden="true"></i>
            {{#str}} create_labs, local_virtuallab {{/str}}
        </a>
    </div>
    <form id="local-virtuallab-bulk-form"
          method="post"
          action="{{manageurl}}">
        <input type="hidden" name="batchid" value="{{batchid}}">
        <input type="hidden" name="sesskey" value="{{sesskey}}">

        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead>
                    <tr>
                        <th scope="col" class="text-center local-virtuallab-select-col">
                            <input type="checkbox"
                                   id="local-virtuallab-selectall"
                                   data-action="toggle"
                                   data-togglegroup="labs-select"
                                   data-toggle="master"
                                   aria-label="{{#str}} selectall, core {{/str}}">
                        </th>
                        <th scope="col">{{#str}} column_lab, local_virtuallab {{/str}}</th>
                        <th scope="col">{{#str}} column_shortname, local_virtuallab {{/str}}</th>
                        <th scope="col">{{#str}} lastreset, local_virtuallab {{/str}}</th>
                        {{#divergent}}
                        <th scope="col">{{#str}} next_action, local_virtuallab {{/str}}</th>
                        {{/divergent}}
                        <th scope="col" class="text-end"
                            aria-label="{{#str}} actions, core {{/str}}"></th>
                    </tr>
                </thead>
                <tbody>
                    {{#labs}}
                    <tr>
                        <td class="text-center">
                            <input type="checkbox"
                                   class="local-virtuallab-lab-checkbox"
                                   name="labids[]"
                                   value="{{id}}"
                                   data-action="toggle"
                                   data-togglegroup="labs-select"
                                   data-toggle="slave"
                                   aria-label="{{coursename}}">
                        </td>
                        <td>
                            <a href="{{courseurl}}">{{coursename}}</a>
                        </td>
                        <td><code>{{shortname}}</code></td>
                        <td>{{lastreset}}</td>
                        {{#divergent}}
                        <td class="text-nowrap">{{nextaction}}</td>
                        {{/divergent}}
                        <td class="text-end text-nowrap">
                            <a href="{{reseturl}}"
                               class="btn btn-sm btn-outline-warning me-1"
                               aria-label="{{resetlabel}}">
                                <i class="fa fa-rotate-right" aria-hidden="true"></i>
                                {{#str}} reset_lab, local_virtuallab {{/str}}
                            </a>
                            <a href="{{deleteurl}}"
                               class="btn btn-sm btn-outline-danger"
                               aria-label="{{deletelabel}}">
                                <i class="fa fa-trash" aria-hidden="true"></i>
                                {{#str}} delete_lab, local_virtuallab {{/str}}
                            </a>
                        </td>
                    </tr>
                    {{/labs}}
                </tbody>
            </table>
        </div>

        <div class="d-flex align-items-center local-virtuallab-bulk-actions mt-2">
            <label for="local-virtuallab-bulkaction" class="mb-0 text-nowrap">
                {{#str}} bulk_action, local_virtuallab {{/str}}:
            </label>
            <select id="local-virtuallab-bulkaction"
                    name="bulkaction"
                    class="form-select form-select-sm local-virtuallab-bulk-select">
                <option value="">—</option>
                <option value="reset">{{#str}} bulk_action_reset, local_virtuallab {{/str}}</option>
                <option value="delete">{{#str}} bulk_action_delete, local_virtuallab {{/str}}</option>
            </select>
            <button type="submit" class="btn btn-sm btn-secondary">
                {{#str}} go, core {{/str}}
            </button>
        </div>
    </form>
    {{/haslabs}}
    {{^haslabs}}
    <div class="text-center py-5">
        <p class="text-body-secondary mb-3">{{#str}} nolabs, local_virtuallab {{/str}}</p>
        <a href="{{createurl}}" class="btn btn-success">
            <i class="fa fa-plus me-1" aria-hidden="true"></i>
            {{#str}} create_labs, local_virtuallab {{/str}}
        </a>
    </div>
    {{/haslabs}}
</div>
{{#js}}
require(['core/copy_to_clipboard', 'core/checkbox-toggleall']);
{{/js}}
